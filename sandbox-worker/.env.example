# Chave compartilhada com o Rails (gerada por bot_service_key.rb na 1ª boot do Rails)
BOT_SERVICE_KEY=

# Postgres compartilhado (mesmo do bot e Rails) — para gravar bots.sandbox_runs
DATABASE_URL=postgres://postgres:senha@host:porta/assinatura_bot?sslmode=disable

# Override opcional
SANDBOX_IMAGE=tzolkin/sandbox-py:v1
LOG_RUNS=true
