# =============================================
# Assinatura - Gabi Bot | Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================

# Aplicação
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_INSTANCE=nome-da-instancia

# Números da Gabi no WhatsApp (formato: 5511999999999 - sem + ou espaços)
GABI_PHONE=5511999999999       # número principal (comercial ou pessoal)
GABI_PHONE_2=                  # segundo número (opcional)

# Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# PostgreSQL
POSTGRES_URL=postgres://postgres:senha@host:porta/banco?sslmode=disable

# Redis
REDIS_URL=redis://default:senha@host:porta

# Asana
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
# GID da seção "Reuniões Mensais" dentro do projeto de atas
ASANA_SECTION_GID=
# GID do usuário Gabi no Asana (veja em: app.asana.com/api/1.0/users/me)
ASANA_USER_GID=

# Rails admin-api — credential broker
# RAILS_BOT_SERVICE_KEY é gerada automaticamente na primeira boot do Rails e logada no console
RAILS_API_URL=http://localhost:3000
RAILS_BOT_SERVICE_KEY=

# Google OAuth (login do dashboard + conector Drive)
# Crie um projeto em console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback do Drive (FastAPI): https://seubot.com/auth/drive/callback
GOOGLE_OAUTH_REDIRECT_URI=https://seubot.com/auth/drive/callback
# URL de callback do login (Next.js): https://seuadmin.com/api/auth/google/callback
GOOGLE_LOGIN_REDIRECT_URI=https://seuadmin.com/api/auth/google/callback
# E-mails permitidos no login (separados por vírgula). Vazio = qualquer conta Google.
GOOGLE_ALLOWED_EMAILS=admin@suaempresa.com
# Senha para proteger a rota /auth/drive (acesso ao OAuth do Drive)
OAUTH_SECRET=troque-por-uma-senha-forte

# Dashboard Admin (Next.js)
ADMIN_SESSION_SECRET=troque-por-uma-chave-aleatoria-longa
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=senha-forte-aqui
NEXT_PUBLIC_API_URL=https://seubot.com
NEXT_PUBLIC_OAUTH_SECRET=mesma-senha-do-OAUTH_SECRET

# Mensagens automáticas (opcional - já tem padrão definido no config.py)
# AUTO_REPLY_MEETING_MSG=Oi! Estou em reunião no momento...
# AUTO_REPLY_EVENT_MSG=Oi! Estou em um evento no momento...
